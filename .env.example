# Yojana Sahayak — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env — it is in .gitignore.

# ── Required for Telegram bot ─────────────────────────────────────────────────
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# ── Optional: production webhook (Railway / Render / Fly.io URL) ─────────────
# Leave empty to use polling mode (fine for development)
WEBHOOK_URL=

# ── Optional: HuggingFace token (only needed for private model downloads) ────
HF_TOKEN=
