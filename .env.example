# Yojana Sahayak — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env — it is in .gitignore.

# ── Required for Telegram bot ─────────────────────────────────────────────────
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# ── Required for cloud LLM + ASR (free tier at console.groq.com) ─────────────
GROQ_API_KEY=

# ── Optional: production webhook (Railway / Render / Fly.io URL) ─────────────
# Leave empty to use polling mode (fine for development)
WEBHOOK_URL=

# ── Optional: override the Groq chat model ───────────────────────────────────
# Default: llama-3.1-8b-instant (fast, free-tier, good Hindi)
# Alternatives: llama-3.3-70b-versatile, gemma2-9b-it
GROQ_MODEL=llama-3.1-8b-instant

# ── Optional: Bhashini / AI4Bharat TTS for higher-quality Hindi voice ────────
AI4BHARAT_API_KEY=

# ── Optional: HuggingFace token (only needed for private model downloads) ────
HF_TOKEN=
